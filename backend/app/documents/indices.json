  "tasks_v1": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "analysis": {
        "analyzer": {
          "task_analyzer": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": ["lowercase", "russian_stop", "russian_stemmer"]
          }
        },
        "filter": {
          "russian_stop": { "type": "stop", "stopwords": "_russian_" },
          "russian_stemmer": { "type": "stemmer", "language": "russian" }
        }
      }
    },
    "mappings": {
